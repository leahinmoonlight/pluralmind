{
    "name": "pluralmind",
    "version": "1.2.0",
    "description": "Let folks know who's speaking. Pluralmind allows plural folks to share which of their members is sending a message on Twitch.",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "prepare": "pnpm build",
        "docs:api": "typedoc",
        "docs:dev": "pnpm docs:api && vitepress dev docs",
        "docs:build": "pnpm docs:api && vitepress build docs",
        "docs:deploy": "pnpm docs:build && wrangler pages deploy docs/.vitepress/dist --project-name pluralmind-docs"
    },
    "keywords": [
        "pluralmind",
        "plurality",
        "plural",
        "twitch",
        "headmate"
    ],
    "author": "leahinmoonlight",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/leahinmoonlight/pluralmind.git"
    },
    "homepage": "https://docs.pluralmind.chat",
    "devEngines": {
        "packageManager": {
            "name": "pnpm",
            "version": "^11.6.0",
            "onFail": "download"
        }
    },
    "type": "module",
    "devDependencies": {
        "@catppuccin/vitepress": "^0.1.2",
        "tsdown": "^0.22.3",
        "typedoc": "^0.28.19",
        "typedoc-plugin-markdown": "^4.12.0",
        "typedoc-vitepress-theme": "^1.1.3",
        "typescript": "^6.0.3",
        "vitepress": "^1.6.4",
        "vue": "^3.5.38",
        "wrangler": "^4.103.0"
    },
    "files": [
        "dist"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.cts",
    "unpkg": "./dist/index.iife.js",
    "jsdelivr": "./dist/index.iife.js",
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    }
}
